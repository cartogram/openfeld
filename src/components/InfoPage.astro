---
import type { Translations } from "../i18n";
import { HOURS, MONTH_NAMES } from "../data/hours";

interface Props {
  t: Translations;
  locale: string;
}

const { t, locale } = Astro.props;
const homeHref = locale === "en" ? "/" : `/${locale}/`;
---

<main class="info-page" transition:animate="fade">
  <header class="info-header">
    <h1>Tempelhof Feld</h1>
    <a href={homeHref} class="back-link">&larr; {t.back}</a>
  </header>

  <section>
    <h2>{t.openingHours}</h2>
    <table>
      <thead>
        <tr>
          <th>{t.monthHeader}</th>
          <th>{t.openHeader}</th>
          <th>{t.closeHeader}</th>
        </tr>
      </thead>
      <tbody>
        {
          Object.entries(HOURS).map(([month, entry]) => (
            <tr>
              <td>{MONTH_NAMES[Number(month)]}</td>
              <td>{entry.open}</td>
              <td>
                {entry.lateClose
                  ? `${entry.close} / ${entry.lateClose}`
                  : entry.close}
                {entry.splitDay && (
                  <span class="note">
                    ({t.from} {MONTH_NAMES[Number(month)]} {entry.splitDay})
                  </span>
                )}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>

  <section>
    <h2>{t.about}</h2>
    <p>{t.aboutText}</p>
  </section>

  <section>
    <h2>{t.links}</h2>
    <ul class="links">
      <li>
        <a
          href="https://mattseccafien.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          mattseccafien.com
        </a>
      </li>
      <li>
        <a
          href="https://www.tempelhofer-feld.berlin.de"
          target="_blank"
          rel="noopener noreferrer"
        >
          tempelhofer-feld.berlin.de
        </a>
        — {t.officialSite}
      </li>
      <li>
        <a
          href="https://www.thf100.de"
          target="_blank"
          rel="noopener noreferrer"
        >
          100% Tempelhofer Feld
        </a>
        — {t.thf100Desc}
      </li>
    </ul>
  </section>
</main>

<style>
  .info-page {
    position: relative;
    z-index: 1;
    background-color: var(--color-bg);
    max-width: 32rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    min-height: 100dvh;
  }

  .info-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  h1 {
    font-size: 1.25rem;
    font-weight: 600;
  }

  .back-link {
    color: var(--color-text);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s ease;
    font-size: 0.9375rem;
  }

  .back-link:hover,
  .back-link:focus-visible {
    opacity: 1;
  }

  h2 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-variant-numeric: tabular-nums;
  }

  th,
  td {
    padding: 0.25rem 0.5rem;
    text-align: left;
  }

  th {
    font-weight: 600;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.7;
    border-bottom: 1px solid color-mix(in srgb, currentColor 15%, transparent);
  }

  td {
    font-size: 0.875rem;
  }

  tr:not(:last-child) td {
    border-bottom: 1px solid color-mix(in srgb, currentColor 8%, transparent);
  }

  .note {
    font-size: 0.75rem;
    opacity: 0.7;
    display: block;
  }

  p {
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .links a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .links a:hover,
  .links a:focus-visible {
    opacity: 0.8;
  }
</style>
