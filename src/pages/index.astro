---
import { getRelativeLocaleUrl } from "astro:i18n";
import Base from "../layouts/Base.astro";
import { getTranslations } from "../i18n";

const locale = Astro.currentLocale ?? "en";
const t = getTranslations(locale);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Openfeld",
    url: "https://openfeld.cartogram.ca",
    inLanguage: ["en", "de"],
    description: "Check if Tempelhof Feld is open right now",
  },
  {
    "@context": "https://schema.org",
    "@type": "Park",
    name: "Tempelhofer Feld",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Berlin",
      addressCountry: "DE",
    },
    url: "https://openfeld.cartogram.ca",
  },
];
---

<Base
  title={t.title}
  locale={locale}
  description={t.descriptionHome}
  url="/"
  alternateLocale="de"
  alternateUrl="/de/"
  jsonLd={jsonLd}
>
  <footer class="info-link">
    <a href={getRelativeLocaleUrl(locale, "/info")}>Info</a>
  </footer>
</Base>

<style>
  .info-link {
    position: fixed;
    bottom: 2rem;
    left: 0;
    right: 0;
    text-align: center;
  }

  .info-link a {
    color: var(--color-text);
    font-size: clamp(0.875rem, 2vw, 1rem);
    opacity: 0.6;
    transition: opacity 0.2s ease;
    text-decoration: none;
    padding: 0.5rem 1rem;
  }

  .info-link a:hover,
  .info-link a:focus-visible {
    opacity: 1;
  }
</style>
